<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>J.A.R.V.I.S. - STARK INDUSTRIES</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700&family=Rajdhani:wght@300;500;700&display=swap');

        :root {
            --stark-blue: #00d2ff;
            --stark-dark: #050a14;
            --stark-border: rgba(0, 210, 255, 0.3);
            --stark-glow: rgba(0, 210, 255, 0.15);
        }

        body {
            background-color: var(--stark-dark);
            background-image: 
                radial-gradient(circle at 50% 50%, rgba(0, 40, 80, 0.4) 0%, transparent 80%),
                linear-gradient(rgba(0, 210, 255, 0.05) 1px, transparent 1px),
                linear-gradient(90s, rgba(0, 210, 255, 0.05) 1px, transparent 1px);
            background-size: 100% 100%, 30px 30px, 30px 30px;
            color: var(--stark-blue);
            font-family: 'Rajdhani', sans-serif;
            height: 100vh;
            width: 100vw;
            margin: 0;
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .hud-container {
            width: 95%;
            height: 90%;
            border: 2px solid var(--stark-border);
            position: relative;
            background: rgba(5, 10, 20, 0.8);
            backdrop-filter: blur(10px);
            display: flex;
            flex-direction: column;
            clip-path: polygon(0 0, 95% 0, 100% 5%, 100% 100%, 5% 100%, 0 95%);
        }

        .hud-header {
            padding: 20px;
            border-bottom: 1px solid var(--stark-border);
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: linear-gradient(90deg, rgba(0, 210, 255, 0.1) 0%, transparent 100%);
        }

        .stark-logo {
            font-family: 'Orbitron', sans-serif;
            letter-spacing: 4px;
            font-weight: 700;
            text-shadow: 0 0 10px var(--stark-blue);
        }

        #chat-container {
            flex-grow: 1;
            overflow-y: auto;
            padding: 30px;
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        .message-jarvis {
            background: rgba(0, 210, 255, 0.05);
            border-left: 3px solid var(--stark-blue);
            padding: 15px;
            max-width: 80%;
            position: relative;
            clip-path: polygon(0 0, 100% 0, 100% 80%, 95% 100%, 0 100%);
        }

        .message-user {
            align-self: flex-end;
            background: rgba(255, 255, 255, 0.05);
            border-right: 3px solid #fff;
            padding: 15px;
            max-width: 80%;
            text-align: right;
            clip-path: polygon(5% 0, 100% 0, 100% 100%, 0 100%, 0 20%);
        }

        .input-area {
            padding: 25px;
            background: rgba(0, 0, 0, 0.4);
            border-top: 1px solid var(--stark-border);
        }

        .stark-input {
            background: transparent;
            border: 1px solid var(--stark-border);
            color: white;
            padding: 15px 20px;
            width: 100%;
            outline: none;
            font-family: 'Rajdhani', sans-serif;
            font-size: 1.1rem;
            transition: all 0.3s;
        }

        .stark-input:focus {
            box-shadow: 0 0 15px var(--stark-glow);
            border-color: var(--stark-blue);
        }

        .scanline {
            width: 100%;
            height: 2px;
            background: rgba(0, 210, 255, 0.1);
            position: absolute;
            animation: scan 4s linear infinite;
            z-index: 10;
            pointer-events: none;
        }

        @keyframes scan {
            0% { top: 0; }
            100% { top: 100%; }
        }

        .glitch-text {
            animation: glitch 2s infinite;
        }

        @keyframes glitch {
            0% { opacity: 1; }
            50% { opacity: 0.8; }
            100% { opacity: 1; }
        }

        ::-webkit-scrollbar { width: 4px; }
        ::-webkit-scrollbar-thumb { background: var(--stark-blue); }
    </style>
</head>
<body>

    <div class="scanline"></div>

    <div class="hud-container">
        <!-- HEADER -->
        <header class="hud-header">
            <div class="flex flex-col">
                <h1 class="stark-logo text-xl">J.A.R.V.I.S.</h1>
                <span class="text-[10px] tracking-[0.3em] opacity-60">SISTEMA OPERATIVO DE APOYO V.2.0</span>
            </div>
            <div class="text-right font-mono">
                <div class="text-xs opacity-50">PROPIEDAD DE STARK INDUSTRIES</div>
                <div id="clock" class="text-lg font-bold">00:00:00</div>
                <div class="text-[9px] text-emerald-400">ENLACE NEURAL: CARLOS MANUEL PANAMEÑO MARCENARO</div>
            </div>
        </header>

        <!-- CHAT -->
        <div id="chat-container">
            <div class="message-jarvis">
                <p class="text-lg">Sistemas reiniciados, Señor Carlos. He purgado los errores de renderizado y optimizado la respuesta visual del HUD. Estamos operando bajo protocolos de seguridad Nivel 10. ¿Cuál es su próximo movimiento?</p>
                <span class="text-[10px] opacity-40 mt-2 block tracking-widest">SUBRUTINA_INICIO_COMPLETA</span>
            </div>
        </div>

        <!-- LOADING -->
        <div id="loading" class="hidden px-8 py-2 text-[10px] tracking-[0.5em] animate-pulse italic">
            PROCESANDO DATOS EN NÚCLEO GEMINI...
        </div>

        <!-- INPUT -->
        <div class="input-area">
            <div class="relative flex items-center gap-4">
                <div class="flex-grow">
                    <input 
                        type="text" 
                        id="user-input" 
                        placeholder="INGRESE COMANDO..." 
                        class="stark-input uppercase tracking-widest"
                        autocomplete="off"
                    >
                </div>
                <button id="send-btn" class="border border-sky-500 p-4 hover:bg-sky-500/20 transition-all active:scale-95">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"/></svg>
                </button>
            </div>
            <div class="mt-4 flex justify-between items-center opacity-40 text-[9px] tracking-widest uppercase">
                <span>Estado del reactor: Estable</span>
                <span>Usuario autenticado: ADMIN_CARLOS</span>
            </div>
        </div>
    </div>

    <script>
        const apiKey = ""; 
        const chatContainer = document.getElementById('chat-container');
        const userInput = document.getElementById('user-input');
        const sendBtn = document.getElementById('send-btn');
        const loading = document.getElementById('loading');

        // Reloj Stark
        function tick() {
            document.getElementById('clock').textContent = new Date().toLocaleTimeString('es-ES', {hour12: false});
        }
        setInterval(tick, 1000);
        tick();

        function appendMessage(role, text) {
            const div = document.createElement('div');
            div.className = role === 'user' ? 'message-user' : 'message-jarvis';
            div.innerHTML = `<p class="${role === 'user' ? '' : 'text-lg'}">${text}</p>
                             <span class="text-[9px] opacity-30 mt-2 block tracking-widest uppercase">${role === 'user' ? 'Comando_Entrante' : 'Respuesta_Sistema'}</span>`;
            chatContainer.appendChild(div);
            chatContainer.scrollTop = chatContainer.scrollHeight;
        }

        async function talkToJarvis(prompt) {
            const url = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`;
            const payload = {
                contents: [{ parts: [{ text: prompt }] }],
                systemInstruction: { 
                    parts: [{ text: "Eres J.A.R.V.I.S., la IA de Tony Stark. Tu jefe es el Señor Carlos (Carlos Manuel Panameño Marcenaro). Eres británico, extremadamente educado, eficiente, con un sentido del humor seco. Usa términos como 'Señor', 'Protocolos', 'Sistemas'. Mantén las respuestas claras pero con ese toque de asistente de alta tecnología." }] 
                },
                tools: [{ "google_search": {} }]
            };

            for (let i = 0; i < 5; i++) {
                try {
                    const response = await fetch(url, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(payload)
                    });
                    const data = await response.json();
                    return data.candidates?.[0]?.content?.parts?.[0]?.text || "Anomalía detectada en el flujo de datos.";
                } catch (e) {
                    await new Promise(r => setTimeout(r, 1000 * Math.pow(2, i)));
                }
            }
            return "Sistemas fuera de línea. Reintente.";
        }

        async function handleAction() {
            const val = userInput.value.trim();
            if(!val) return;

            appendMessage('user', val);
            userInput.value = '';
            loading.classList.remove('hidden');

            try {
                const resp = await talkToJarvis(val);
                appendMessage('jarvis', resp);
            } finally {
                loading.classList.add('hidden');
            }
        }

        sendBtn.onclick = handleAction;
        userInput.onkeydown = (e) => e.key === 'Enter' && handleAction();
    </script>
</body>
</html>
